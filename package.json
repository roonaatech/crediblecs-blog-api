{
  "name": "crediblecs-blog-api",
  "version": "1.0.0",
  "description": "Blog backend API for CredibleCS website - Node.js + Express + MySQL",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:setup": "node database/setup.js",
    "db:seed": "node database/seed.js",
    "db:reset": "node database/setup.js && node database/seed.js"
  },
  "keywords": [
    "blog",
    "api",
    "crediblecs",
    "express",
    "mysql"
  ],
  "author": "CredibleCS",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
